  "roles": {
    "hasDtc": {
      "domain": "Engine",
      "range": "Symptom"
    },
    "hasCondition": {
      "domain": "Engine",
      "range": "Condition"
    },
    "hasTrend": {
      "domain": "Engine",
      "range": "Trend"
    }
  },
  "classes": {
    "MisfireUnderLoad": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.CylinderMisfire ⊔ ∃hasCondition.FailedMisfireMonitor) ⊓ (∃hasCondition.HighLoad ⊔ ∃hasTrend.RecurringHighLoad)"
    },
    "CamCrankCorrelationFault": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.CamCrankCorrelation"
    },
    "LeanFuelBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.LeanCodeBank1 ⊓ (∃hasCondition.PositiveFuelTrim ⊔ ∃hasTrend.RisingFuelTrim)"
    },
    "LeanFuelBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.LeanCodeBank2 ⊓ (∃hasCondition.PositiveFuelTrim ⊔ ∃hasTrend.RisingFuelTrim)"
    },
    "RichFuelBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.RichCodeBank1 ⊓ (∃hasCondition.NegativeFuelTrim ⊔ ∃hasTrend.FallingFuelTrim)"
    },
    "RichFuelBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.RichCodeBank2 ⊓ (∃hasCondition.NegativeFuelTrim ⊔ ∃hasTrend.FallingFuelTrim)"
    },
    "EvapLeakSmall": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.EvapCodeSmall ⊔ ∃hasCondition.FailedEvapMonitorSmall)"
    },
    "EvapLeakLarge": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.EvapCodeLarge ⊔ ∃hasCondition.FailedEvapMonitorLarge)"
    },
    "CatalystEfficiencyBank1": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.CatalystCodeBank1 ⊔ ∃hasCondition.FailedCatalystMonitorBank1)"
    },
    "CatalystEfficiencyBank2": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.CatalystCodeBank2 ⊔ ∃hasCondition.FailedCatalystMonitorBank2)"
    },
    "O2CircuitFaultBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2CircuitBank1"
    },
    "O2CircuitFaultBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2CircuitBank2"
    },
    "O2PerformanceFaultBank1": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2PerformanceBank1 ⊔ ∃hasCondition.FailedO2MonitorBank1)"
    },
    "O2PerformanceFaultBank2": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2PerformanceBank2 ⊔ ∃hasCondition.FailedO2MonitorBank2)"
    },
    "O2HeaterFaultBank1": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2HeaterBank1 ⊔ ∃hasCondition.FailedO2HeaterMonitorBank1)"
    },
    "O2HeaterFaultBank2": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2HeaterBank2 ⊔ ∃hasCondition.FailedO2HeaterMonitorBank2)"
    },
    "ChronicOilConsumption": {
      "equivalentTo": "Engine ⊓ ∃hasTrend.OilLevelDecline"
    },
    "MultiAirOilStarvation": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.MultiAirFault ⊓ ∃hasCondition.LowOilPressure"
    },
    "O2DownstreamCircuitFaultBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2DownstreamCircuitBank1"
    },
    "O2DownstreamCircuitFaultBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2DownstreamCircuitBank2"
    },
    "O2DownstreamPerformanceFaultBank1": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2DownstreamPerformanceBank1 ⊔ ∃hasCondition.FailedO2DownstreamMonitorBank1)"
    },
    "O2DownstreamPerformanceFaultBank2": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2DownstreamPerformanceBank2 ⊔ ∃hasCondition.FailedO2DownstreamMonitorBank2)"
    },
    "O2DownstreamHeaterFaultBank1": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2DownstreamHeaterBank1 ⊔ ∃hasCondition.FailedO2DownstreamHeaterMonitorBank1)"
    },
    "O2DownstreamHeaterFaultBank2": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.O2DownstreamHeaterBank2 ⊔ ∃hasCondition.FailedO2DownstreamHeaterMonitorBank2)"
    },
    "EgrFlowFault": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.EgrFlowCode ⊔ ∃hasCondition.FailedEgrMonitor)"
    },
    "EgrCircuitFault": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.EgrCircuitCode"
    },
    "SecondaryAirSystemFault": {
      "equivalentTo": "Engine ⊓ (∃hasDtc.SecondaryAirCode ⊔ ∃hasCondition.FailedSecondaryAirMonitor)"
    }
  },
