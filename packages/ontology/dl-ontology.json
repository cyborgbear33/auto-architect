    "OilLevelDecline": "Trend",
    "RisingFuelTrim": "Trend",
    "FallingFuelTrim": "Trend",
    "RecurringHighLoad": "Trend"
  },
  "roles": {
    "hasDtc": {
      "domain": "Engine",
      "range": "Symptom"
    },
    "hasCondition": {
      "domain": "Engine",
      "range": "Condition"
    },
    "hasTrend": {
      "domain": "Engine",
      "range": "Trend"
    }
  },
  "classes": {
    "MisfireUnderLoad": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.CylinderMisfire ⊓ (∃hasCondition.HighLoad ⊔ ∃hasTrend.RecurringHighLoad)"
    },
    "CamCrankCorrelationFault": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.CamCrankCorrelation"
    },
    "LeanFuelBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.LeanCodeBank1 ⊓ (∃hasCondition.PositiveFuelTrim ⊔ ∃hasTrend.RisingFuelTrim)"
    },
    "LeanFuelBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.LeanCodeBank2 ⊓ (∃hasCondition.PositiveFuelTrim ⊔ ∃hasTrend.RisingFuelTrim)"
    },
    "RichFuelBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.RichCodeBank1 ⊓ (∃hasCondition.NegativeFuelTrim ⊔ ∃hasTrend.FallingFuelTrim)"
    },
    "RichFuelBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.RichCodeBank2 ⊓ (∃hasCondition.NegativeFuelTrim ⊔ ∃hasTrend.FallingFuelTrim)"
    },
    "EvapLeakSmall": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.EvapCodeSmall"
    },
    "EvapLeakLarge": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.EvapCodeLarge"
    },
    "CatalystEfficiencyBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.CatalystCodeBank1"
    },
    "CatalystEfficiencyBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.CatalystCodeBank2"
    },
    "O2CircuitFaultBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2CircuitBank1"
    },
    "O2CircuitFaultBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2CircuitBank2"
    },
    "O2HeaterFaultBank1": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2HeaterBank1"
    },
    "O2HeaterFaultBank2": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.O2HeaterBank2"
    },
    "ChronicOilConsumption": {
      "equivalentTo": "Engine ⊓ ∃hasTrend.OilLevelDecline"
    },
    "MultiAirOilStarvation": {
      "equivalentTo": "Engine ⊓ ∃hasDtc.MultiAirFault ⊓ ∃hasCondition.LowOilPressure"
    }
  },
  "notes": {
    "MisfireUnderLoad": "SAE-generic (any manufacturer): P0300-P0304 + high load now, or recurring high-load samples from forecast.",
