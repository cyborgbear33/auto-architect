{
  "name": "@auto/ontology",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The ontology owns fault meaning: the DL TBox (dl-ontology.json), the vehicle-profile registry, the DTC dictionary, and known manufacturer campaigns.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dl-ontology.json": "./dl-ontology.json",
    "./vehicle-profiles.json": "./vehicle-profiles.json",
    "./dtc-dictionary.json": "./dtc-dictionary.json",
    "./known-campaigns.json": "./known-campaigns.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@auto/semantic-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
